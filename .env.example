# Optional: enables the photoreal Google 3D campus tour (Tier 2).
#
# Create a key in Google Cloud Console with the **Map Tiles API** enabled,
# then restrict it by HTTP referrer (e.g. https://banksy1224.github.io/*) since
# the key ships in the client bundle. Without this var, campus tours fall back
# to the stylized 3D scene.
#
# Local dev:   copy this file to `.env.local` and fill in the key.
# Deploy:      add it as a GitHub repo secret named VITE_GOOGLE_MAPS_API_KEY.
VITE_GOOGLE_MAPS_API_KEY=

# Optional: enables the AI concierge ("Ask the guide").
# Set to your deployed backend URL (see server/README.md), e.g.
# https://your-app.up.railway.app . Without it, the concierge stays hidden.
VITE_AI_ENDPOINT=
